+- (PHAsset *)_assetForURL:(NSURL *)assetURL
+{
+    // Try to extract the local identifier from the assets-library URL
+    // assets-library URLs contain the asset UUID in the query string as id=
+    NSURLComponents *components = [NSURLComponents componentsWithURL:assetURL resolvingAgainstBaseURL:NO];
+    NSString *assetId = nil;
+    for (NSURLQueryItem *item in components.queryItems) {
+        if ([item.name isEqualToString:@"id"]) {
+            assetId = item.value;
+            break;
+        }
+    }
+    if (assetId) {
+        // Try fetching by the UUID portion with common suffix formats
+        NSArray *suffixes = @[@"/L0/001", @"/L0/002", @""];
+        for (NSString *suffix in suffixes) {
+            NSString *localId = [NSString stringWithFormat:@"%@%@", assetId, suffix];
+            PHFetchResult *result = [PHAsset fetchAssetsWithLocalIdentifiers:@[localId] options:nil];
+            if (result.firstObject) {
+                return result.firstObject;
+            }
+        }
+    }
+    // Fallback: cannot resolve legacy assets-library URL
+    return nil;
+}
